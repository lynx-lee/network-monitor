# Dependencies
node_modules/

# Build outputs
dist/
build/

# Git history (large, not needed for builds)
.git/
.gitignore

# Deploy files (avoid recursive COPY, but keep nginx.conf for frontend build)
deploy/*.sh
deploy/*.sql
deploy/*.yml
deploy/Dockerfile*
backups/

# Documentation and tests (not needed in image)
docs/
tests/
README.md
CONTRIBUTING.md
ARCHITECTURE.md

# Environment files (injected at runtime, not baked in)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
.trae/
.codebuddy/
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
coverage/
*.lcov

# Temporary files
*.tmp
*.temp
.cache/

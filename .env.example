# ============================================================
# Network Monitor - 环境变量配置
# 使用方法: cp .env.example .env && 修改以下敏感配置
# ============================================================

# --- 数据库配置 (部署前必须修改密码) ---
MYSQL_ROOT_PASSWORD=your_secure_root_password
DB_HOST=db
DB_PORT=3306
DB_USER=network_monitor
DB_PASSWORD=your_secure_db_password
DB_NAME=network_monitor
DB_CONNECTION_LIMIT=20

# --- 后端服务配置 ---
SERVER_PORT=3001
SERVER_HOST=0.0.0.0
NODE_ENV=production

# --- 日志配置 ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- CORS / 前端来源 ---
CLIENT_ORIGIN=http://localhost:8090

# --- 前端环境变量 (Vite 编译时注入) ---
# VITE_API_URL=/api
# VITE_WS_URL=/
